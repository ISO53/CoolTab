{
    "manifest_version": 3,
    "name": "Cool Tab",
    "version": "1.11.0",
    "description": "Just a new tab for your browser, but cooler",
    "chrome_url_overrides": {
        "newtab": "index.html"
    },
    "host_permissions": [
        "https://query1.finance.yahoo.com/*",
        "https://query2.finance.yahoo.com/*",
        "https://cool-tab-api.vercel.app/*"
    ]
}
